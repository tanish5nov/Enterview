{
  "name": "ai-swe-mock-interviewer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm --prefix client run dev\" \"npm --prefix server run dev\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "lint": "npm run lint:client && npm run lint:server",
    "lint:client": "npm --prefix client run lint",
    "lint:server": "npm --prefix server run lint",
    "build:client": "npm --prefix client run build",
    "start:server": "npm --prefix server run start"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0"
  }
}
